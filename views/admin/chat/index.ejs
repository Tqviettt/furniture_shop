<div class="container-fluid py-4">
  <div class="row" style="height: 75vh;">
    <!-- Sidebar: Danh sách chat rooms -->
    <div class="col-md-4 col-lg-3 h-100 bg-white border rounded shadow-sm d-flex flex-column p-0 me-3">
      <div class="p-3 border-bottom bg-light">
        <h5 class="mb-0 fw-bold">Tin nhắn khách hàng</h5>
      </div>
      <div class="list-group list-group-flush flex-grow-1 overflow-auto" id="chatRoomList">
        <% if (chatRooms && chatRooms.length > 0) { %>
          <% chatRooms.forEach(room => { %>
            <a href="#" class="list-group-item list-group-item-action chat-room-btn" data-room="<%= room._id %>">
              <div class="d-flex w-100 justify-content-between">
                <h6 class="mb-1 fw-bold"><%= room.customer.name %></h6>
                <small class="text-muted"><%= new Date(room.lastMessage.createdAt).toLocaleTimeString('vi-VN', {hour: '2-digit', minute:'2-digit'}) %></small>
              </div>
              <p class="mb-1 text-truncate text-muted small"><%= room.lastMessage.content %></p>
            </a>
          <% }) %>
        <% } else { %>
          <div class="p-3 text-center text-muted">Chưa có tin nhắn nào.</div>
        <% } %>
      </div>
    </div>

    <!-- Main Chat Area -->
    <div class="col h-100 bg-white border rounded shadow-sm d-flex flex-column p-0">
      <div class="p-3 border-bottom bg-light d-flex align-items-center">
        <h5 class="mb-0 fw-bold" id="activeChatName">Chọn một cuộc hội thoại</h5>
      </div>
      <div class="flex-grow-1 p-3 overflow-auto" id="chatBox" style="background-color: #f8f9fa;">
        <div class="text-center text-muted mt-5">Vui lòng chọn khách hàng để bắt đầu chat.</div>
      </div>
      <div class="p-3 border-top bg-white d-none" id="chatInputArea">
        <form id="chatForm" class="d-flex gap-2">
          <input type="text" id="chatInput" class="form-control rounded-pill px-3" placeholder="Nhập tin nhắn..." autocomplete="off" required>
          <button type="submit" class="btn btn-primary rounded-circle" style="width:45px; height:45px;"><i class="fas fa-paper-plane"></i></button>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = io();
  const currentUser = <%- JSON.stringify(currentUser) %>;
  let activeRoom = null;

  // Tham gia phòng của admin để nhận mọi tin nhắn mới
  socket.emit("join_admin");

  socket.on("receive_message", (msg) => {
    if (activeRoom && msg.room === activeRoom) {
      appendMessage(msg);
      scrollToBottom();
    }
  });

  document.querySelectorAll('.chat-room-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      // Đổi style active
      document.querySelectorAll('.chat-room-btn').forEach(b => b.classList.remove('active', 'bg-primary', 'text-white'));
      btn.classList.add('active', 'bg-primary', 'text-white');
      const p = btn.querySelector('p');
      const small = btn.querySelector('small');
      if(p) p.classList.remove('text-muted');
      if(small) small.classList.remove('text-muted');

      activeRoom = btn.getAttribute('data-room');
      const customerName = btn.querySelector('h6').innerText;
      document.getElementById('activeChatName').innerText = customerName;
      document.getElementById('chatInputArea').classList.remove('d-none');

      // Load tin nhắn
      const res = await fetch(`/chat/messages/${activeRoom}`);
      const data = await res.json();
      
      const chatBox = document.getElementById('chatBox');
      chatBox.innerHTML = '';
      if(data.success && data.messages.length > 0) {
        data.messages.forEach(msg => appendMessage(msg));
      } else {
        chatBox.innerHTML = '<div class="text-center text-muted mt-3">Chưa có tin nhắn.</div>';
      }
      scrollToBottom();
    });
  });

  document.getElementById('chatForm').addEventListener('submit', (e) => {
    e.preventDefault();
    const content = document.getElementById('chatInput').value.trim();
    if(!content || !activeRoom) return;

    socket.emit("send_message", {
      room: activeRoom,
      sender: currentUser.id,
      content: content
    });

    document.getElementById('chatInput').value = '';
  });

  function appendMessage(msg) {
    const isMe = msg.sender._id === currentUser.id;
    const div = document.createElement('div');
    div.className = `d-flex flex-column mb-3 ${isMe ? 'align-items-end' : 'align-items-start'}`;
    
    let senderName = '';
    if (!isMe) {
      senderName = `<small class="text-muted mb-1">${msg.sender.name}</small>`;
    }

    div.innerHTML = `
      ${senderName}
      <div class="px-3 py-2 rounded-3 ${isMe ? 'bg-primary text-white' : 'bg-white border shadow-sm'}" style="max-width: 75%;">
        ${msg.content}
      </div>
      <small class="text-muted mt-1" style="font-size: 0.7rem;">
        ${new Date(msg.createdAt).toLocaleTimeString('vi-VN', {hour: '2-digit', minute:'2-digit'})}
      </small>
    `;
    document.getElementById('chatBox').appendChild(div);
  }

  function scrollToBottom() {
    const box = document.getElementById('chatBox');
    box.scrollTop = box.scrollHeight;
  }
</script>
