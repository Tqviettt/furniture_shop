<div class="container-fluid py-4">
  <div class="d-flex justify-content-between mb-3">
    <h3> Quản Lý Mã Giảm Giá</h3>
    <a href="/admin/coupons/create" class="btn btn-primary"> Thêm Mã Mới</a>
  </div>

  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead class="table-dark">
        <tr>
          <th>Mã Code</th>
          <th>Loại</th>
          <th>Giá trị</th>
          <th>Đơn tối thiểu</th>
          <th>Đã dùng / Tối đa</th>
          <th>Ngày hết hạn</th>
          <th>Trạng thái</th>
          <th>Thao tác</th>
        </tr>
      </thead>
      <tbody>
        <% if (coupons && coupons.length > 0) { %>
          <% coupons.forEach(c => { %>
          <tr>
            <td class="fw-bold"><%= c.code %></td>
            <td>
              <% if (c.discountType === 'percent') { %>
                <span class="badge bg-info">Phần trăm (%)</span>
              <% } else { %>
                <span class="badge bg-secondary">Tiền mặt</span>
              <% } %>
            </td>
            <td class="text-danger fw-bold">
              <%= c.discountType === 'percent' ? c.discountValue + '%' : c.discountValue.toLocaleString('vi-VN') + 'đ' %>
            </td>
            <td><%= c.minOrder.toLocaleString('vi-VN') %>đ</td>
            <td><%= c.usedCount %> / <%= c.maxUses %></td>
            <td>
              <%= c.expiryDate ? new Date(c.expiryDate).toLocaleDateString('vi-VN') : 'Không giới hạn' %>
            </td>
            <td>
              <% if (c.isActive) { %>
                <span class="badge bg-success">Hoạt động</span>
              <% } else { %>
                <span class="badge bg-danger">Vô hiệu</span>
              <% } %>
            </td>
            <td>
              <a href="/admin/coupons/<%= c._id %>/edit" class="btn btn-outline-primary btn-sm">Sửa</a>
              <form action="/admin/coupons/<%= c._id %>?_method=DELETE" method="POST" class="d-inline">
                <button class="btn btn-outline-danger btn-sm" onclick="return confirm('Bạn có chắc chắn muốn xóa mã này?')">Xóa</button>
              </form>
            </td>
          </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="8" class="text-center py-4">Chưa có mã giảm giá nào.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
