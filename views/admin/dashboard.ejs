<div class="container-fluid py-4">
  <h3> Admin Dashboard</h3>
  <div class="row g-4 mt-2">
    <div class="col-md-3">
      <div class="card bg-primary text-white p-3 shadow">
        <h2><%= stats.totalProducts %></h2>
        <p class="mb-0"> Sản phẩm</p>
        <a href="/admin/products" class="text-white small">Quản lý →</a>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card bg-success text-white p-3 shadow">
        <h2><%= stats.totalUsers %></h2>
        <p class="mb-0"> Khách hàng</p>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card bg-warning text-white p-3 shadow">
        <h2><%= stats.totalOrders %></h2>
        <p class="mb-0"> Đơn hàng</p>
        <a href="/admin/orders" class="text-white small">Quản lý →</a>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card bg-danger text-white p-3 shadow">
        <h2><%= stats.revenue.toLocaleString('vi-VN') %>đ</h2>
        <p class="mb-0"> Doanh thu</p>
      </div>
    </div>
  </div>

  <div class="row mt-4">
    <div class="col-md-6">
      <div class="card p-3">
        <h5> Truy cập nhanh</h5>
        <div class="list-group mt-2">
          <a href="/admin/products/create" class="list-group-item list-group-item-action"> Thêm sản phẩm mới</a>
          <a href="/admin/products" class="list-group-item list-group-item-action"> Quản lý sản phẩm</a>
          <a href="/admin/orders" class="list-group-item list-group-item-action"> Quản lý đơn hàng</a>
        </div>
      </div>
    </div>
  </div>
</div>