<div class="container-fluid py-4">
  <h3 class="mb-4 text-dark serif"> Admin Dashboard - Báo Cáo Thống Kê</h3>
  
  <!-- Thẻ thống kê tổng quan -->
  <div class="row g-4 mb-4">
    <div class="col-md-3">
      <div class="card bg-primary text-white p-3 shadow h-100 border-0">
        <h2 class="fw-bold"><%= stats.totalProducts %></h2>
        <p class="mb-0"> Sản phẩm</p>
        <a href="/admin/products" class="text-white small text-decoration-none mt-2">Quản lý <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card bg-success text-white p-3 shadow h-100 border-0">
        <h2 class="fw-bold"><%= stats.totalUsers %></h2>
        <p class="mb-0"> Khách hàng</p>
        <a href="/admin/users" class="text-white small text-decoration-none mt-2">Quản lý <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card bg-warning text-dark p-3 shadow h-100 border-0">
        <h2 class="fw-bold"><%= stats.totalOrders %></h2>
        <p class="mb-0"> Đơn hàng</p>
        <a href="/admin/orders" class="text-dark small text-decoration-none mt-2">Quản lý <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card bg-danger text-white p-3 shadow h-100 border-0">
        <h2 class="fw-bold"><%= stats.revenue.toLocaleString('vi-VN') %>đ</h2>
        <p class="mb-0"> Doanh thu (Đã giao)</p>
      </div>
    </div>
  </div>

  <!-- Biểu đồ -->
  <div class="row g-4 mb-4">
    <div class="col-md-8">
      <div class="card shadow border-0 h-100">
        <div class="card-header bg-white pt-3 pb-2">
          <h5 class="mb-0 text-dark">Doanh thu 7 ngày gần nhất</h5>
        </div>
        <div class="card-body">
          <canvas id="revenueChart" style="max-height: 300px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow border-0 h-100">
        <div class="card-header bg-white pt-3 pb-2">
          <h5 class="mb-0 text-dark">Trạng thái đơn hàng</h5>
        </div>
        <div class="card-body d-flex justify-content-center align-items-center">
          <canvas id="statusChart" style="max-height: 250px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Cảnh báo tồn kho -->
  <% if (typeof lowStockProducts !== 'undefined' && lowStockProducts.length > 0) { %>
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-warning shadow-sm">
        <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
          <h5 class="mb-0"><i class="fas fa-exclamation-triangle me-2"></i> Cảnh báo sắp hết hàng</h5>
          <a href="/admin/inventory" class="btn btn-sm btn-dark">Nhập kho ngay</a>
        </div>
        <div class="card-body p-0">
          <ul class="list-group list-group-flush">
            <% lowStockProducts.forEach(p => { %>
            <li class="list-group-item d-flex justify-content-between align-items-center">
              <div class="d-flex align-items-center">
                <img src="<%= p.images && p.images.length ? p.images[0] : '/images/no-image.png' %>" alt="" style="width: 40px; height: 40px; object-fit: cover;" class="rounded me-3">
                <span class="fw-bold"><%= p.name %></span>
              </div>
              <span class="badge bg-danger rounded-pill">Chỉ còn: <%= p.stock %></span>
            </li>
            <% }) %>
          </ul>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Bảng dữ liệu -->
  <div class="row g-4">
    <!-- Sản phẩm bán chạy -->
    <div class="col-md-6">
      <div class="card shadow border-0 h-100">
        <div class="card-header bg-white d-flex justify-content-between align-items-center pt-3 pb-2">
          <h5 class="mb-0 text-dark">Top Sản Phẩm Bán Chạy</h5>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-3 border-0">Sản phẩm</th>
                  <th class="text-center border-0">Đã bán</th>
                  <th class="text-end pe-3 border-0">Doanh thu</th>
                </tr>
              </thead>
              <tbody>
                <% topProducts.forEach(item => { %>
                  <tr>
                    <td class="ps-3 d-flex align-items-center">
                      <img src="<%= item.image || '/images/no-image.png' %>" alt="" style="width: 45px; height: 45px; object-fit: cover;" class="rounded me-3 border">
                      <span class="text-truncate fw-medium text-dark" style="max-width: 200px;"><%= item.name %></span>
                    </td>
                    <td class="text-center"><span class="badge bg-primary rounded-pill px-3"><%= item.totalQuantity %></span></td>
                    <td class="text-end pe-3 text-danger fw-bold"><%= item.totalRevenue.toLocaleString('vi-VN') %>đ</td>
                  </tr>
                <% }) %>
                <% if(!topProducts || topProducts.length === 0) { %>
                  <tr><td colspan="3" class="text-center py-4 text-muted">Chưa có dữ liệu thống kê sản phẩm</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Đơn hàng mới nhất -->
    <div class="col-md-6">
      <div class="card shadow border-0 h-100">
        <div class="card-header bg-white d-flex justify-content-between align-items-center pt-3 pb-2">
          <h5 class="mb-0 text-dark">Đơn Hàng Mới Nhất</h5>
          <a href="/admin/orders" class="btn btn-sm btn-outline-primary rounded-pill px-3">Xem tất cả</a>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-3 border-0">Khách hàng</th>
                  <th class="border-0">Tổng tiền</th>
                  <th class="border-0">Trạng thái</th>
                  <th class="text-end pe-3 border-0">Thời gian</th>
                </tr>
              </thead>
              <tbody>
                <% recentOrders.forEach(order => { %>
                  <tr>
                    <td class="ps-3 fw-medium text-dark"><%= order.user ? order.user.name : 'Khách vô danh' %></td>
                    <td class="fw-bold"><%= order.total.toLocaleString('vi-VN') %>đ</td>
                    <td>
                      <% if(order.orderStatus === 'pending') { %><span class="badge bg-warning text-dark">Chờ duyệt</span><% } %>
                      <% if(order.orderStatus === 'confirmed') { %><span class="badge bg-info text-dark">Đã duyệt</span><% } %>
                      <% if(order.orderStatus === 'shipping') { %><span class="badge bg-primary">Đang giao</span><% } %>
                      <% if(order.orderStatus === 'delivered') { %><span class="badge bg-success">Đã giao</span><% } %>
                      <% if(order.orderStatus === 'cancelled') { %><span class="badge bg-danger">Đã hủy</span><% } %>
                    </td>
                    <td class="text-end pe-3 text-muted small"><%= new Date(order.createdAt).toLocaleDateString('vi-VN') %></td>
                  </tr>
                <% }) %>
                <% if(!recentOrders || recentOrders.length === 0) { %>
                  <tr><td colspan="4" class="text-center py-4 text-muted">Chưa có đơn hàng nào gần đây</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Tích hợp Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", function() {
    // 1. Biểu đồ Doanh thu (Line chart)
    const revenueDataRaw = <%- JSON.stringify(revenueChart || []) %>;
    if(revenueDataRaw.length > 0) {
      const labelsRevenue = revenueDataRaw.map(item => {
        const d = new Date(item.date);
        return d.getDate() + '/' + (d.getMonth() + 1);
      });
      const dataRevenue = revenueDataRaw.map(item => item.revenue);

      const ctxRev = document.getElementById('revenueChart').getContext('2d');
      new Chart(ctxRev, {
        type: 'line',
        data: {
          labels: labelsRevenue,
          datasets: [{
            label: 'Doanh thu',
            data: dataRevenue,
            borderColor: '#dc3545',
            backgroundColor: 'rgba(220, 53, 69, 0.15)',
            borderWidth: 2,
            fill: true,
            tension: 0.4,
            pointBackgroundColor: '#dc3545',
            pointBorderColor: '#fff',
            pointBorderWidth: 2,
            pointRadius: 5,
            pointHoverRadius: 7
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: function(context) {
                  return context.parsed.y.toLocaleString('vi-VN') + 'đ';
                }
              }
            }
          },
          scales: {
            y: { 
              beginAtZero: true, 
              grid: { borderDash: [5, 5] },
              ticks: { callback: function(value) { return value.toLocaleString('vi-VN') + 'đ'; } } 
            },
            x: {
              grid: { display: false }
            }
          }
        }
      });
    }

    // 2. Biểu đồ Trạng thái (Doughnut chart)
    const statusDataRaw = <%- JSON.stringify(statusStats || []) %>;
    if(statusDataRaw.length > 0) {
      const statusMap = {
        'pending': 'Chờ duyệt',
        'confirmed': 'Đã duyệt',
        'shipping': 'Đang giao',
        'delivered': 'Đã giao',
        'cancelled': 'Đã hủy'
      };
      const colorMap = {
        'pending': '#ffc107',
        'confirmed': '#0dcaf0',
        'shipping': '#0d6efd',
        'delivered': '#198754',
        'cancelled': '#dc3545'
      };

      const labelsStatus = statusDataRaw.map(item => statusMap[item._id] || item._id);
      const dataStatus = statusDataRaw.map(item => item.count);
      const bgColors = statusDataRaw.map(item => colorMap[item._id] || '#6c757d');

      const ctxStat = document.getElementById('statusChart').getContext('2d');
      new Chart(ctxStat, {
        type: 'doughnut',
        data: {
          labels: labelsStatus,
          datasets: [{
            data: dataStatus,
            backgroundColor: bgColors,
            borderWidth: 2,
            borderColor: '#fff',
            hoverOffset: 4
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          cutout: '70%',
          plugins: {
            legend: { 
              position: 'bottom',
              labels: { padding: 20, usePointStyle: true }
            }
          }
        }
      });
    }
  });
</script>