<div class="container-fluid py-4">
  <div class="d-flex justify-content-between mb-3">
    <h3> Quản Lý Kho Hàng</h3>
    <a href="/admin/inventory/logs" class="btn btn-outline-info"> Lịch sử nhập kho</a>
  </div>

  <div class="card p-3 mb-4 shadow-sm">
    <form action="/admin/inventory" method="GET" class="d-flex gap-2">
      <input type="text" name="q" class="form-control" placeholder="Tìm tên sản phẩm..." value="<%= typeof q !== 'undefined' ? q : '' %>" />
      <button type="submit" class="btn btn-primary">Tìm kiếm</button>
    </form>
  </div>

  <div class="table-responsive bg-white rounded shadow-sm p-3">
    <table class="table table-hover align-middle">
      <thead class="table-dark">
        <tr>
          <th>Sản phẩm</th>
          <th>Tồn kho hiện tại</th>
          <th>Thao tác nhập kho</th>
        </tr>
      </thead>
      <tbody>
        <% if (products && products.length > 0) { %>
          <% products.forEach(p => { %>
          <tr>
            <td>
              <div class="d-flex align-items-center">
                <img src="<%= p.images && p.images.length ? p.images[0] : '/images/no-image.png' %>" alt="" style="width: 50px; height: 50px; object-fit: cover" class="me-3 rounded">
                <div>
                  <div class="fw-bold"><%= p.name %></div>
                  <div class="small text-muted"><%= p.price.toLocaleString('vi-VN') %>đ</div>
                </div>
              </div>
            </td>
            <td>
              <% if (p.stock <= 5) { %>
                <span class="badge bg-danger"><%= p.stock %> (Sắp hết)</span>
              <% } else { %>
                <span class="badge bg-success"><%= p.stock %></span>
              <% } %>
            </td>
            <td>
              <form action="/admin/inventory/add" method="POST" class="d-flex gap-2" style="max-width: 300px;">
                <input type="hidden" name="productId" value="<%= p._id %>">
                <input type="number" name="quantity" class="form-control form-control-sm" placeholder="Số lượng" min="1" required>
                <input type="text" name="reason" class="form-control form-control-sm" placeholder="Ghi chú (Tùy chọn)">
                <button type="submit" class="btn btn-success btn-sm">Nhập</button>
              </form>
            </td>
          </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="3" class="text-center py-4">Không tìm thấy sản phẩm.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
