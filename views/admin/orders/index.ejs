<div class="container-fluid py-4">
  <h3> Quản Lý Đơn Hàng</h3>
  <div class="card bg-success text-white p-3 mb-4 d-inline-block">
    <h5> Doanh thu: <%= revenue.toLocaleString('vi-VN') %>đ</h5>
  </div>

  <table class="table table-hover">
    <thead class="table-dark">
      <tr>
        <th>Mã đơn</th><th>Khách hàng</th><th>Tổng tiền</th><th>Trạng thái</th><th>Thao tác</th>
      </tr>
    </thead>
    <tbody>
      <% orders.forEach(order => { %>
      <tr>
        <td><small>#<%= order._id.toString().slice(-8).toUpperCase() %></small></td>
        <td><%= order.user?.name || 'N/A' %></td>
        <td><%= order.total.toLocaleString('vi-VN') %>đ</td>
        <td>
          <span class="badge bg-<%= order.orderStatus === 'delivered' ? 'success' : order.orderStatus === 'cancelled' ? 'danger' : 'warning' %>">
            <%= order.orderStatus %>
          </span>
        </td>
        <td>
          <form action="/admin/orders/<%= order._id %>/status?_method=PUT" method="POST" class="d-flex gap-2">
            <select name="status" class="form-select form-select-sm" style="width:150px;">
              <% ['pending','confirmed','shipping','delivered','cancelled'].forEach(s => { %>
              <option value="<%= s %>" <%= order.orderStatus === s ? 'selected' : '' %>><%= s %></option>
              <% }) %>
            </select>
            <button class="btn btn-primary btn-sm">Cập nhật</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>