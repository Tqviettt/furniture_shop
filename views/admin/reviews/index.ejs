<div class="container py-4">
  <div class="d-flex justify-content-between mb-3">
    <h3>Quản lý Đánh giá</h3>
  </div>

  <div class="card p-3 shadow-sm">
    <table class="table table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th>Sản phẩm</th>
          <th>Người dùng</th>
          <th>Sao</th>
          <th>Nội dung</th>
          <th>Ngày tạo</th>
          <th>Hành động</th>
        </tr>
      </thead>
      <tbody>
        <% if (reviews && reviews.length > 0) { %>
        <% reviews.forEach(review => { %>
        <tr>
          <td>
            <% if (review.product) { %>
              <a href="/products/<%= review.product._id %>" class="text-decoration-none">
                <img src="<%= review.product.images[0] || '/images/no-image.png' %>" width="40" class="me-2 rounded">
                <%= review.product.name %>
              </a>
            <% } else { %>
              <span class="text-muted">Sản phẩm đã xóa</span>
            <% } %>
          </td>
          <td>
            <strong><%= review.userName %></strong><br>
            <small class="text-muted"><%= review.user ? review.user.email : '' %></small>
          </td>
          <td>
            <span class="text-warning">
              <% for(let i=1; i<=5; i++) { %>
                <%= i <= review.rating ? '★' : '☆' %>
              <% } %>
            </span>
          </td>
          <td>
            <div><%= review.comment %></div>
            <% if (review.reply) { %>
              <div class="mt-2 p-2 bg-light rounded text-muted small border-start border-3 border-primary">
                <strong><i class="fas fa-reply me-1"></i> Phản hồi:</strong> <%= review.reply %>
              </div>
            <% } %>
          </td>
          <td><%= new Date(review.createdAt).toLocaleDateString('vi-VN') %></td>
          <td>
            <div class="d-flex flex-column gap-2">
              <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#replyModal<%= review._id %>">Phản hồi</button>
              <form action="/admin/reviews/<%= review._id %>?_method=DELETE" method="POST" class="d-inline">
                <button class="btn btn-sm btn-outline-danger w-100" onclick="return confirm('Xóa đánh giá này?')">Xóa</button>
              </form>
            </div>

            <!-- Modal Phản hồi -->
            <div class="modal fade" id="replyModal<%= review._id %>" tabindex="-1">
              <div class="modal-dialog">
                <div class="modal-content">
                  <form action="/admin/reviews/<%= review._id %>/reply?_method=PUT" method="POST">
                    <div class="modal-header">
                      <h5 class="modal-title">Phản hồi đánh giá của <%= review.userName %></h5>
                      <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                      <p><strong>Khách hàng nói:</strong> <%= review.comment %></p>
                      <div class="mb-3">
                        <label class="form-label">Nội dung phản hồi:</label>
                        <textarea name="reply" class="form-control" rows="4" required><%= review.reply || '' %></textarea>
                      </div>
                    </div>
                    <div class="modal-footer">
                      <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                      <button type="submit" class="btn btn-primary">Gửi phản hồi</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </td>
        </tr>
        <% }) %>
        <% } else { %>
        <tr>
          <td colspan="6" class="text-center py-4">Chưa có đánh giá nào.</td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
