<!-- Banner Slideshow -->
<div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
  <div class="carousel-indicators">
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
  </div>

  <div class="carousel-inner">
    <div class="carousel-item active">
      <div class="hero-slide"
        style="background-image: url('/images/sofa.png'); background-size: cover; background-position: center;">
        <div class="container h-100 d-flex align-items-center">
          <div class="text-white col-md-6">
            <h1 class="display-3 fw-bold serif">Đẳng Cấp Không Gian</h1>
            <p class="lead text-light">Bộ sưu tập Sofa Minimalism mang đến sự sang trọng và tinh tế tuyệt đối cho phòng
              khách của bạn.</p>
            <a href="/products" class="btn btn-light btn-lg mt-3 rounded-0 px-5 text-dark">Khám Phá Ngay</a>
          </div>
        </div>
      </div>
    </div>

    <div class="carousel-item">
      <div class="hero-slide"
        style="background-image: url('/images/bed.png'); background-size: cover; background-position: center;">
        <div class="container h-100 d-flex align-items-center justify-content-end text-end">
          <div class="text-white col-md-6">
            <h1 class="display-3 fw-bold serif">Giấc Ngủ Hoàn Mỹ</h1>
            <p class="lead text-light">Thiết kế giường ngủ mang đậm nét thiền định, cho bạn những phút giây thư giãn
              trọn vẹn.</p>
            <a href="/products/category/giuong" class="btn btn-light btn-lg mt-3 rounded-0 px-5 text-dark">Xem
              Giường</a>
          </div>
        </div>
      </div>
    </div>

    <div class="carousel-item">
      <div class="hero-slide"
        style="background-image: url('/images/table.png'); background-size: cover; background-position: center;">
        <div class="container h-100 d-flex align-items-center">
          <div class="text-white col-md-6">
            <h1 class="display-3 fw-bold serif">Nghệ Thuật Bàn Trà</h1>
            <p class="lead text-light">Mỗi chiếc bàn là một tác phẩm nghệ thuật, là tâm điểm của sự kết nối.</p>
            <a href="/products/category/ban" class="btn btn-light btn-lg mt-3 rounded-0 px-5 text-dark">Mua Ngay</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>
</div>

<!-- Sản phẩm nổi bật -->
<div class="container py-5 my-5">
  <h2 class="text-center mb-5 fw-light text-uppercase serif">Sản Phẩm Nổi Bật</h2>
  <div class="row g-5">
    <% featured.forEach(product=> { %>
      <div class="col-md-3 col-sm-6">
        <div class="card product-card h-100 border-0">
          <div class="product-img-wrapper">
            <img src="<%= product.images[0] || '/images/no-image.png' %>" class="card-img-top product-img"
              alt="<%= product.name %>" />
            <div class="product-actions">
              <a href="/products/<%= product._id %>"
                class="btn btn-light btn-sm rounded-0 flex-fill py-2 text-dark fw-bold">Chi Tiết</a>
              <button class="btn btn-dark btn-sm rounded-0 py-2 add-to-cart flex-fill fw-bold"
                data-id="<%= product._id %>">
                <i class="fas fa-cart-plus"></i> Thêm Giỏ
              </button>
            </div>
          </div>
          <div class="card-body d-flex flex-column px-0 pt-3 pb-0">
            <h6 class="card-title serif fs-5 mb-1">
              <%= product.name %>
            </h6>
            <div class="mt-auto">
              <% if (product.salePrice> 0) { %>
                <span class="text-danger fw-bold">
                  <%= product.salePrice.toLocaleString('vi-VN') %>đ
                </span>
                <small class="text-muted text-decoration-line-through ms-2">
                  <%= product.price.toLocaleString('vi-VN') %>đ
                </small>
                <% } else { %>
                  <span class="fw-bold">
                    <%= product.price.toLocaleString('vi-VN') %>đ
                  </span>
                  <% } %>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
  </div>
</div>

<!-- Cam Kết Dịch Vụ (Features) -->
<div class="bg-light py-5 mt-4 border-top border-bottom">
  <div class="container">
    <div class="row g-4 text-center">
      <div class="col-md-3 col-sm-6">
        <div class="mb-3"><i class="far fa-gem text-danger fs-2"></i></div>
        <h5 class="fw-bold serif mb-3">Giao Hàng</h5>
        <p class="text-muted small">Kỹ thuật tự vận chuyển, lắp đặt tận nhà trên toàn quốc.</p>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="mb-3"><i class="fas fa-medal text-danger fs-2"></i></div>
        <h5 class="fw-bold serif mb-3">Chất Lượng</h5>
        <p class="text-muted small">Thiết kế bắt mắt, mẫu mã đa dạng, vật liệu cao cấp bền bỉ.</p>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="mb-3"><i class="fas fa-shield-alt text-danger fs-2"></i></div>
        <h5 class="fw-bold serif mb-3">Bảo Hành</h5>
        <p class="text-muted small">Chế độ bảo hành dài hạn, tận tâm, nhanh chóng và kịp thời.</p>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="mb-3"><i class="fas fa-headset text-danger fs-2"></i></div>
        <h5 class="fw-bold serif mb-3">Tư Vấn</h5>
        <p class="text-muted small">Tư vấn viên chuyên nghiệp, hỗ trợ trực tiếp hoặc qua hotline.</p>
      </div>
    </div>
  </div>
</div>

<!-- Tin Tức & Góc Chia Sẻ -->
<div class="container py-5 my-5">
  <h2 class="text-center mb-5 fw-light text-uppercase serif">Góc Tin Tức & Chia Sẻ</h2>
  <div class="row g-4">
    <% if (newsList && newsList.length===0) { %>
      <div class="col-12 text-center text-muted">Đang cập nhật bài viết...</div>
      <% } %>
        <% if (newsList) { newsList.forEach(news=> { %>
          <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm news-card">
              <a href="/news/<%= news.slug %>" class="text-decoration-none">
                <div class="position-relative overflow-hidden" style="height: 220px;">
                  <img src="<%= news.image %>" class="w-100 h-100 object-fit-cover hover-zoom" alt="<%= news.title %>">
                  <div
                    class="position-absolute top-0 start-0 bg-white m-3 text-center p-2 shadow-sm border border-danger"
                    style="min-width: 50px;">
                    <span class="d-block fw-bold text-danger fs-5">
                      <%= new Date(news.createdAt).getDate() %>
                    </span>
                    <span class="d-block small text-muted text-uppercase">Th<%= new Date(news.createdAt).getMonth() + 1
                        %></span>
                  </div>
                  <span class="position-absolute top-0 end-0 bg-danger text-white px-2 py-1 m-3 small rounded fw-bold">
                    <%= news.category %>
                  </span>
                </div>
              </a>
              <div class="card-body p-4 text-center">
                <h5 class="card-title fw-bold mb-3 mt-2">
                  <a href="/news/<%= news.slug %>"
                    class="text-dark text-decoration-none hover-danger text-uppercase serif"
                    style="font-size: 1.05rem;">
                    <%= news.title %>
                  </a>
                </h5>
                <p class="card-text text-muted small mb-4" style="line-height: 1.6;">
                  <%= news.excerpt %>
                </p>
                <a href="/news/<%= news.slug %>" class="text-danger fw-bold text-decoration-none small">XEM THÊM</a>
              </div>
            </div>
          </div>
          <% }) } %>
  </div>
</div>