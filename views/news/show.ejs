<div class="container py-5 my-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Trang chủ</a></li>
          <li class="breadcrumb-item"><a href="/news" class="text-decoration-none text-muted">Tin tức</a></li>
          <li class="breadcrumb-item active" aria-current="page"><%= news.title %></li>
        </ol>
      </nav>

      <div class="mb-4">
        <span class="badge bg-danger me-2"><%= news.category %></span>
        <span class="text-muted small"><i class="far fa-calendar-alt me-1"></i> <%= new Date(news.createdAt).toLocaleDateString('vi-VN') %></span>
        <% if (news.author) { %>
          <span class="text-muted small ms-3"><i class="far fa-user me-1"></i> <%= news.author.name %></span>
        <% } %>
      </div>

      <h1 class="fw-bold serif mb-4"><%= news.title %></h1>
      
      <div class="lead text-muted mb-5 border-start border-danger border-4 ps-3">
        <%= news.excerpt %>
      </div>

      <img src="<%= news.image %>" class="img-fluid w-100 rounded mb-5 shadow-sm" style="max-height: 500px; object-fit: cover;" alt="<%= news.title %>">

      <div class="news-content" style="line-height: 1.8; font-size: 1.1rem; color: #444;">
        <%- news.content %>
      </div>

      <hr class="my-5">
      <div class="d-flex justify-content-between align-items-center">
        <a href="/news" class="btn btn-outline-dark">← Về danh sách tin tức</a>
      </div>
    </div>
  </div>
</div>
