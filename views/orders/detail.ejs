<div class="container py-4">
  <div class="card mb-4 p-4 shadow-sm">
    <h5> Trạng thái đơn hàng</h5>
    <div class="order-timeline mt-3">
      <%
        const steps = [
          { key: 'pending', label: 'Chờ xác nhận', icon: '' },
          { key: 'confirmed', label: 'Đã xác nhận', icon: '' },
          { key: 'shipping', label: 'Đang giao', icon: '' },
          { key: 'delivered', label: 'Đã giao', icon: '' },
        ];
        const statusOrder = ['pending','confirmed','shipping','delivered'];
        const currentIndex = statusOrder.indexOf(order.orderStatus);
      %>
      <div class="d-flex justify-content-between position-relative">
        <div class="timeline-line"></div>
        <% steps.forEach((step, index) => { %>
        <div class="timeline-step text-center <%= index <= currentIndex && order.orderStatus !== 'cancelled' ? 'active' : '' %>">
          <div class="timeline-icon"><%= step.icon %></div>
          <small><%= step.label %></small>
        </div>
        <% }) %>
      </div>
      <% if (order.orderStatus === 'cancelled') { %>
      <div class="alert alert-danger mt-3 text-center"> Đơn hàng đã bị hủy</div>
      <% } %>
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3> Chi Tiết Đơn Hàng</h3>
    <a href="/orders/my-orders" class="btn btn-outline-secondary">← Quay lại</a>
  </div>

  <div class="row">
    <div class="col-md-8">
      <div class="card mb-3">
        <div class="card-body">
          <h5>Sản phẩm đã đặt</h5>
          <% order.items.forEach(item => { %>
          <div class="d-flex align-items-center gap-3 mb-3 pb-3 border-bottom">
            <img src="<%= item.image %>" style="width:70px;height:70px;object-fit:cover;" class="rounded" />
            <div class="flex-fill">
              <p class="mb-0 fw-bold"><%= item.name %></p>
              <small class="text-muted">SL: <%= item.quantity %></small>
            </div>
            <span class="text-danger fw-bold">
              <%= (item.price * item.quantity).toLocaleString('vi-VN') %>đ
            </span>
          </div>
          <% }) %>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card mb-3">
        <div class="card-body">
          <h5>Địa chỉ giao hàng</h5>
          <p class="mb-1"><strong><%= order.shippingAddress.name %></strong></p>
          <p class="mb-1"> <%= order.shippingAddress.phone %></p>
          <p class="mb-0"> <%= order.shippingAddress.street %>, <%= order.shippingAddress.city %></p>
        </div>
      </div>

      <div class="card">
        <div class="card-body">
          <h5>Tóm tắt</h5>
          <div class="d-flex justify-content-between"><span>Tạm tính:</span><span><%= order.subtotal.toLocaleString('vi-VN') %>đ</span></div>
          <div class="d-flex justify-content-between"><span>Phí ship:</span><span><%= order.shippingFee === 0 ? 'Miễn phí' : order.shippingFee.toLocaleString('vi-VN') + 'đ' %></span></div>
          <hr />
          <div class="d-flex justify-content-between fw-bold text-danger">
            <span>Tổng:</span><span><%= order.total.toLocaleString('vi-VN') %>đ</span>
          </div>

          <% if (order.orderStatus === 'pending') { %>
          <form action="/orders/<%= order._id %>/cancel?_method=PUT" method="POST" class="mt-3" onsubmit="return confirm('Hủy đơn hàng này?')">
            <button class="btn btn-danger w-100">
              Hủy đơn hàng
            </button>
          </form>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>