<div class="container py-4">
  <!-- Breadcrumb -->
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
      <li class="breadcrumb-item active">Sản phẩm</li>
    </ol>
  </nav>

  <div class="row">
    <!-- Sidebar bộ lọc -->
    <div class="col-md-3">
      <div class="card p-3 mb-4 shadow-sm">
        <h5> Danh mục</h5>
        <div class="list-group mb-3">
          <a href="/products" class="list-group-item list-group-item-action <%= !category ? 'active' : '' %>">
            Tất cả
          </a>
          <% if (typeof globalCategories !== 'undefined') { %>
            <% globalCategories.forEach(cat => { %>
            <a href="/products?category=<%= cat.slug %>"
              class="list-group-item list-group-item-action <%= category === cat.slug ? 'active' : '' %>">
              <%= cat.name %>
            </a>
            <% }) %>
          <% } %>
        </div>

        <!-- Lọc theo giá -->
        <h5> Khoảng giá</h5>
        <form action="/products" method="GET" id="filterForm">
          <% if (typeof q !== 'undefined' && q) { %>
            <input type="hidden" name="q" value="<%= q %>" />
          <% } %>
          <input type="hidden" name="category" value="<%= category || '' %>" />
          <div class="mb-2">
            <label class="form-label small">Giá tối thiểu</label>
            <input type="number" name="minPrice" class="form-control form-control-sm"
              placeholder="0" value="<%= minPrice || '' %>" />
          </div>
          <div class="mb-2">
            <label class="form-label small">Giá tối đa</label>
            <input type="number" name="maxPrice" class="form-control form-control-sm"
              placeholder="100.000.000" value="<%= maxPrice || '' %>" />
          </div>

          <!-- Lọc theo chất liệu -->
          <h5 class="mt-3"> Chất liệu</h5>
          <select name="material" class="form-select form-select-sm mb-3">
            <option value="">Tất cả</option>
            <option value="go" <%= material === 'go' ? 'selected' : '' %>>Gỗ</option>
            <option value="vai" <%= material === 'vai' ? 'selected' : '' %>>Vải</option>
            <option value="da" <%= material === 'da' ? 'selected' : '' %>>Da</option>
            <option value="sat" <%= material === 'sat' ? 'selected' : '' %>>Sắt</option>
            <option value="nhua" <%= material === 'nhua' ? 'selected' : '' %>>Nhựa</option>
          </select>

          <button type="submit" class="btn btn-primary w-100 btn-sm"> Lọc</button>
          <a href="/products" class="btn btn-outline-secondary w-100 btn-sm mt-2"> Xóa bộ lọc</a>
        </form>
      </div>
    </div>

    <!-- Danh sách sản phẩm -->
    <div class="col-md-9">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5>Tìm thấy <strong><%= total %></strong> sản phẩm</h5>

        <!-- Sắp xếp -->
        <select class="form-select w-auto" id="sortSelect"
          onchange="window.location.href=this.value">
          <% const baseQuery = `/products?${category ? 'category='+category+'&' : ''}${typeof q !== 'undefined' && q ? 'q='+q+'&' : ''}`; %>
          <option value="<%= baseQuery %>sort=newest"
            <%= sort === 'newest' ? 'selected' : '' %>>
             Mới nhất
          </option>
          <option value="<%= baseQuery %>sort=price_asc"
            <%= sort === 'price_asc' ? 'selected' : '' %>>
             Giá tăng dần
          </option>
          <option value="<%= baseQuery %>sort=price_desc"
            <%= sort === 'price_desc' ? 'selected' : '' %>>
             Giá giảm dần
          </option>
          <option value="<%= baseQuery %>sort=best_seller"
            <%= sort === 'best_seller' ? 'selected' : '' %>>
             Bán chạy
          </option>
        </select>
      </div>

      <% if (products.length === 0) { %>
      <div class="text-center py-5">
        <h5 class="text-muted">Không có sản phẩm phù hợp!</h5>
        <a href="/products" class="btn btn-primary mt-3">Xem tất cả</a>
      </div>
      <% } else { %>
      <div class="row g-4">
        <% products.forEach(product => { %>
        <div class="col-md-4 col-sm-6">
          <div class="card product-card h-100 shadow-sm">
            <div class="product-img-wrapper">
              <img src="<%= product.images[0] || '/images/no-image.png' %>"
                class="card-img-top product-img" alt="<%= product.name %>" />
              <% if (product.salePrice > 0) { %>
              <span class="badge bg-danger product-badge">SALE</span>
              <% } %>
              <div class="product-img-overlay">
                <a href="/products/<%= product._id %>" class="btn btn-light btn-sm">
                   Xem chi tiết
                </a>
              </div>
            </div>
            <div class="card-body d-flex flex-column">
              <h6 class="card-title"><%= product.name %></h6>
              <p class="text-muted small mb-1"><%= product.category %></p>
              <div class="mt-auto">
                <% if (product.salePrice > 0) { %>
                <span class="text-danger fw-bold"><%= product.salePrice.toLocaleString('vi-VN') %>đ</span>
                <small class="text-muted text-decoration-line-through ms-2">
                  <%= product.price.toLocaleString('vi-VN') %>đ
                </small>
                <% } else { %>
                <span class="text-primary fw-bold"><%= product.price.toLocaleString('vi-VN') %>đ</span>
                <% } %>
              </div>
              <div class="mt-2 d-flex gap-2">
                <a href="/products/<%= product._id %>" class="btn btn-outline-primary btn-sm flex-fill">
                  Xem chi tiết
                </a>
                <button class="btn btn-warning btn-sm add-to-cart" data-id="<%= product._id %>">
                  <i class="fas fa-cart-plus"></i>
                </button>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>

      <!-- Phân trang -->
      <% if (totalPages > 1) { %>
      <nav class="mt-4">
        <ul class="pagination justify-content-center">
          <% for(let i = 1; i <= totalPages; i++) { %>
          <li class="page-item <%= currentPage === i ? 'active' : '' %>">
            <% const pageQuery = `?page=${i}${category ? '&category='+category : ''}${typeof q !== 'undefined' && q ? '&q='+q : ''}`; %>
            <a class="page-link" href="<%= pageQuery %>">
              <%= i %>
            </a>
          </li>
          <% } %>
        </ul>
      </nav>
      <% } %>
      <% } %>
    </div>
  </div>
</div>