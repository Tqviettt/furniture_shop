<div class="container-fluid py-4">
  <div class="d-flex justify-content-between mb-3">
    <h3> Quản Lý Sản Phẩm</h3>
    <a href="/staff/products/create" class="btn btn-primary"> Thêm sản phẩm</a>
  </div>

  <table class="table table-hover">
    <thead class="table-dark">
      <tr>
        <th>Ảnh</th>
        <th>Tên</th>
        <th>Danh mục</th>
        <th>Giá</th>
        <th>Kho</th>
        <th>Trạng thái duyệt</th>
        <th>Thao tác</th>
      </tr>
    </thead>
    <tbody>
      <% products.forEach(p => { %>
      <tr>
        <td>
          <img src="<%= p.images[0] || '/images/no-image.png' %>"
            style="width:50px;height:50px;object-fit:cover;" class="rounded" />
        </td>
        <td><%= p.name %></td>
        <td><span class="badge bg-secondary"><%= p.category %></span></td>
        <td><%= p.price.toLocaleString('vi-VN') %>đ</td>
        <td><%= p.stock %></td>
        <td>
          <% if (p.approvalStatus === 'pending') { %>
            <span class="badge bg-warning text-dark"> Chờ duyệt</span>
          <% } else if (p.approvalStatus === 'approved') { %>
            <span class="badge bg-success"> Đã duyệt</span>
          <% } else { %>
            <span class="badge bg-danger"> Từ chối</span>
            <% if (p.approvalNote) { %>
            <small class="text-danger d-block"><%= p.approvalNote %></small>
            <% } %>
          <% } %>
        </td>
        <td>
          <!-- Chỉ có nút sửa, không có nút xóa -->
          <a href="/staff/products/<%= p._id %>/edit"
            class="btn btn-warning btn-sm"> Sửa</a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>