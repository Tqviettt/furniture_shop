<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="card shadow">
        <div class="card-body p-4">
          <h3 class="text-center mb-4"> Đăng Nhập</h3>
          <form action="/login" method="POST">
            <div class="mb-3">
              <label class="form-label">Email</label>
              <input type="email" name="email" class="form-control" placeholder="email@gmail.com" required />
            </div>
            <div class="mb-3">
              <label class="form-label">Mật khẩu</label>
              <input type="password" name="password" class="form-control" placeholder="Mật khẩu" required />
            </div>
            <div class="mb-3 text-end">
              <a href="/forgot-password" class="text-decoration-none small text-danger">Quên mật khẩu?</a>
            </div>
            <button type="submit" class="btn btn-primary w-100 mb-3">Đăng Nhập</button>
            <div class="d-flex justify-content-between mb-3 align-items-center">
              <hr class="w-100">
              <span class="mx-3 text-muted small">hoặc</span>
              <hr class="w-100">
            </div>
            <div class="d-flex flex-column gap-2">
              <a href="/auth/google" class="btn btn-outline-danger w-100"><i class="fab fa-google me-2"></i> Đăng nhập với Google</a>
              <a href="/auth/facebook" class="btn btn-outline-primary w-100"><i class="fab fa-facebook-f me-2"></i> Đăng nhập với Facebook</a>
            </div>
          </form>
          <p class="text-center mt-3">
            Chưa có tài khoản? <a href="/register">Đăng ký</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>