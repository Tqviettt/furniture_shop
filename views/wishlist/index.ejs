<div class="container py-4">
  <h3> Sản Phẩm Yêu Thích</h3>
  <% if (items.length === 0) { %>
  <div class="text-center py-5">
    <h5 class="text-muted">Chưa có sản phẩm yêu thích!</h5>
    <a href="/products" class="btn btn-primary mt-3">Khám phá ngay</a>
  </div>
  <% } else { %>
  <div class="row g-4 mt-2">
    <% items.forEach(item => { %>
    <% if (item.product) { %>
    <div class="col-md-3 col-sm-6">
      <div class="card product-card h-100 shadow-sm">
        <div class="product-img-wrapper">
          <img src="<%= item.product.images[0] || '/images/no-image.png' %>"
            class="card-img-top product-img" alt="<%= item.product.name %>" />
        </div>
        <div class="card-body d-flex flex-column">
          <h6><%= item.product.name %></h6>
          <p class="text-primary fw-bold">
            <%= item.product.price.toLocaleString('vi-VN') %>đ
          </p>
          <div class="d-flex gap-2 mt-auto">
            <a href="/products/<%= item.product._id %>"
              class="btn btn-outline-primary btn-sm flex-fill">Xem</a>
            <button class="btn btn-outline-danger btn-sm wishlist-btn"
              data-id="<%= item.product._id %>">🗑️</button>
          </div>
        </div>
      </div>
    </div>
    <% } %>
    <% }) %>
  </div>
  <% } %>
</div>